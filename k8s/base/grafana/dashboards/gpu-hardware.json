  "panels": [
    {
      "id": 1,
      "title": "GPU Utilization %",
      "description": "Fraction of time the GPU is not idle (DCGM_FI_DEV_GPU_UTIL)",
      "type": "gauge",
      "datasource": { "type": "stackdriver", "uid": "P53B7819E0F26D6F4" },
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "minVizValue": 0, "maxVizValue": 100 },
      "targets": [{
        "refId": "A",
        "datasource": { "type": "stackdriver", "uid": "P53B7819E0F26D6F4" },
        "queryType": "timeSeriesList",
        "timeSeriesList": {
          "projectName": "glowally-vllm",
          "crossSeriesReducer": "REDUCE_NONE",
          "alignmentPeriod": "cloud-monitoring-auto",
          "perSeriesAligner": "ALIGN_MEAN",
          "groupBys": [],
          "filters": ["metric.type", "=", "prometheus.googleapis.com/DCGM_FI_DEV_GPU_UTIL/gauge"],
          "preprocessor": "none",
          "view": "FULL"
        }
      }]
    },
