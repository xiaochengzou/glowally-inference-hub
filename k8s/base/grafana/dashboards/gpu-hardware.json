          "calcs": [
            "lastNotNull"
          ]
        },
        "minVizValue": 0,
        "maxVizValue": 100
      },
      "targets": [
        {
          "refId": "A",
          "metricType": "prometheus/DCGM_FI_DEV_GPU_UTIL/gauge",
          "metricKind": "GAUGE",
          "valueType": "DOUBLE",
          "datasource": {
            "type": "cloud-monitoring",
            "uid": "P53B7819E0F26D6F4"
          }
        }
      ],
      "datasource": {
        "type": "cloud-monitoring",
        "uid": "P53B7819E0F26D6F4"
