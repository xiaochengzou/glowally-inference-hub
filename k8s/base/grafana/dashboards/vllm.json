{
  "title": "vLLM Server (Qwen2.5-7B + SQL LoRA)",
  "uid": "vllm-overview",
  "refresh": "30s",
  "schemaVersion": 36,
  "version": 1,
  "panels": [
    {
      "id": 1,
      "title": "Running Requests",
      "type": "stat",
      "datasource": { "type": "stackdriver", "uid": "P53B7819E0F26D6F4" },
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "targets": [{
        "refId": "A",
        "datasource": { "type": "stackdriver", "uid": "P53B7819E0F26D6F4" },
        "queryType": "timeSeriesList",
        "timeSeriesList": {
          "projectName": "glowally-vllm",
          "crossSeriesReducer": "REDUCE_NONE",
          "alignmentPeriod": "cloud-monitoring-auto",
          "perSeriesAligner": "ALIGN_MEAN",
          "groupBys": [],
          "filters": ["metric.type", "=", "prometheus.googleapis.com/vllm:num_requests_running/gauge"],
          "preprocessor": "none",
          "view": "FULL"
        }
      }]
    },
